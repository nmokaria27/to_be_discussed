# Copy to apps/web/.env.local and fill from the InsForge dashboard (Install -> Direct Connect -> API Keys).
# Without these, the app runs in fixture mode (Fake Swarm, no backend).
NEXT_PUBLIC_INSFORGE_URL=https://<appkey>.<region>.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=<anon JWT — publishable, used by the browser SDK + realtime>
INSFORGE_API_KEY=<admin key (ik_...) — server-only, used by the /api/runs orchestrator>
NEXT_PUBLIC_DATA_SOURCE=insforge
